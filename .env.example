NODE_ENV=development
PORT=3001
WEB_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/unisupport
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
JWT_SECRET=replace-with-32-char-min-secret
JWT_REFRESH_SECRET=replace-with-32-char-min-secret
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=unisupport@localhost
SENTRY_DSN=https://key@oID.ingest.sentry.io/projectID

# Google OAuth (optional — only needed for Gmail login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://unisupport.lhtuan.site/api/auth/google/callback
