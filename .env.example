NODE_ENV=development
PORT=3001
WEB_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/unisupport
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
JWT_SECRET=replace-with-32-char-min-secret
JWT_REFRESH_SECRET=replace-with-32-char-min-secret
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=unisupport@localhost
SENTRY_DSN=https://key@oID.ingest.sentry.io/projectID

# SAML SSO (optional — only needed for university IdP login)
SAML_ENTRY_POINT=https://your-university-idp.example.com/saml/sso
SAML_ISSUER=https://unisupport.lhtuan.site
SAML_CERT=-----BEGIN CERTIFICATE-----...-----END CERTIFICATE-----
SAML_CALLBACK_URL=https://unisupport.lhtuan.site/api/auth/saml/callback
